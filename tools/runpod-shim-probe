#!/bin/sh
set -u

section() {
    printf '\n== %s ==\n' "$1"
}

run_optional() {
    title="$1"
    shift
    section "$title"
    "$@" 2>&1 || printf 'unavailable or failed: %s\n' "$*"
}

run_sh() {
    title="$1"
    command="$2"
    section "$title"
    sh -c "$command" 2>&1 || printf 'unavailable or failed: %s\n' "$command"
}

printf 'Runpod Shim Probe\n'
printf 'active modules: gpu_video=%s gpu_ioctl=%s cgroup_memory=%s trace=%s\n' \
    "${RUNPOD_SHIM_GPU_VIDEO:-1}" \
    "${RUNPOD_SHIM_GPU_IOCTL:-1}" \
    "${RUNPOD_SHIM_CGROUP_MEMORY:-1}" \
    "${RUNPOD_SHIM_TRACE:-0}"

run_sh "cgroup memory" "cat /proc/self/cgroup; printf '\n'; grep -E 'cgroup2|memory' /proc/self/mountinfo"
run_sh "host meminfo summary" "grep -E '^(MemTotal|MemAvailable|MemFree):' /proc/meminfo"
run_sh "nvidia devices" "ls -l /dev/nvidia* /dev/nvidia-caps 2>/dev/null"
run_sh "nvidia proc gpus" "find /proc/driver/nvidia/gpus -maxdepth 2 -type f -name information -print -exec grep -H -E 'Bus Location|GPU UUID|Device Minor' {} \; 2>/dev/null"
run_optional "nvidia-smi" nvidia-smi --query-gpu=index,uuid,name,driver_version,pci.bus_id --format=csv
run_sh "ffmpeg nvenc encoders" "ffmpeg -hide_banner -encoders 2>/dev/null | grep -i nvenc"
